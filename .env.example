# WebSocket URL of the server that will receive the parsed telemetry.
# Required. Example: wss://my-server.example.com  or  ws://localhost:3003
SERVER_URL=ws://localhost:3003

# Optional auth token. When set, it is sent as the "x-relay-token" header on
# the WebSocket handshake. Leave blank if your receiving server does not
# authenticate relays.
RELAY_TOKEN=

# UDP port to listen on. EA F1 25 defaults to 20777.
UDP_PORT=20777
